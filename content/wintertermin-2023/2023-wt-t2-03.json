      ],
      "prompt": [
        {
          "t": "text",
          "v": "Stellen Sie unter Verwendung von a und b eine Gleichung zur Berechnung der Wendestellen von f auf."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "open",
        "rubric": [
          {
            "t": "text",
            "v": "Mit f″(x) = 12·a·x² + 2·b lautet die Gleichung zur Berechnung der Wendestellen: 12·a·x² + 2·b = 0."
          }
        ],
        "grader": "ai"
      },
      "scoring": {
        "mode": "rubric",
        "criteria": [
          {
            "desc": "Ein Punkt für das richtige Aufstellen der Gleichung.",
            "points": 1
          }
        ]
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "f'(x) = 4 \\cdot a \\cdot x^{3} + 2 \\cdot b \\cdot x"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "f''(x) = 12 \\cdot a \\cdot x^{2} + 2 \\cdot b"
            }
          ],
          "result": [
            {
              "t": "math",
              "v": "12 \\cdot a \\cdot x^{2} + 2 \\cdot b = 0"
            }
          ],
          "note": "a1) Ein Punkt für das richtige Aufstellen der Gleichung."
        }
      ]
    },
    {
      "id": "2023-wt-t2-03-b1",
