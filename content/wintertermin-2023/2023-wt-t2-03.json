      "prompt": [
        {
          "t": "text",
          "v": "Gegeben ist eine Polynomfunktion g mit "
        },
        {
          "t": "math",
          "v": "g(x) = d \\cdot (x + e)^{2} \\cdot (x - e)^{2} \\quad \\text{mit } d \\neq 0 \\text{ und } e \\in \\mathbb{R}"
        },
        {
          "t": "text",
          "v": ".\nDer Graph von g verläuft durch den Punkt N = (2 | 0).\n\nErmitteln Sie unter diesen Voraussetzungen alle möglichen Werte von e."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "open",
        "rubric": [
          {
            "t": "text",
            "v": "Da g(2) = 0 und d ≠ 0, muss (2 + e)²·(2 − e)² = 0 gelten, also e = −2 bzw. e = 2."
          }
        ],
        "grader": "ai"
      },
      "scoring": {
        "mode": "rubric",
        "criteria": [
          {
            "desc": "Ein Punkt für das richtige Ermitteln aller möglichen Werte von e.",
            "points": 1
          }
        ]
      },
      "points": 1,
      "solution": [
        {
          "result": [
            {
              "t": "math",
              "v": "e = -2 \\ \\text{bzw.} \\ e = 2"
            }
          ],
