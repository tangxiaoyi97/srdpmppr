      ],
      "prompt": [
        {
          "t": "text",
          "v": "Weisen Sie rechnerisch mithilfe der 1. und 2. Ableitung von f nach, dass auf der senkrechten Achse ein Extrempunkt P des Graphen von f liegt."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "open",
        "rubric": [
          {
            "t": "text",
            "v": "Mit f′(x) = 4·a·x³ + 2·b·x gilt f′(0) = 0, und mit f″(x) = 12·a·x² + 2·b gilt f″(0) = 2·b ≠ 0 (da b ≠ 0). Daher ist P = (0 | y_P) ein Extrempunkt von f, der auf der senkrechten Achse liegt."
          }
        ],
        "grader": "ai"
      },
      "scoring": {
        "mode": "rubric",
        "criteria": [
          {
            "desc": "Ein Punkt für das richtige rechnerische Nachweisen.",
            "points": 1
          }
        ]
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "f'(x) = 4 \\cdot a \\cdot x^{3} + 2 \\cdot b \\cdot x"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "f'(0) = 0"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "f''(x) = 12 \\cdot a \\cdot x^{2} + 2 \\cdot b"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "f''(0) = 2 \\cdot b \\neq 0"
            }
          ],
          "result": [
            {
              "t": "math",
              "v": "P = (0 \\mid y_P)"
            },
            {
              "t": "text",
              "v": " ist ein Extrempunkt von f."
            }
          ],
          "note": "b1) Ein Punkt für das richtige rechnerische Nachweisen."
        }
      ]
    },
