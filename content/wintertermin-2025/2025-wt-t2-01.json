      ],
      "prompt": [
        {
          "t": "text",
          "v": "Ein Lieferant von Erdgas möchte bestehende Lieferverträge umstellen. Sophie führt Telefongespräche durch, um Personen mit bestehenden Lieferverträgen von der Vertragsumstellung zu überzeugen.\n\nErfahrungsgemäß gelingt ihr das bei jedem Telefongespräch unabhängig von den anderen Telefongesprächen mit einer Wahrscheinlichkeit von 35 %.\n\nSophie führt pro Woche 200 solche Telefongespräche. Sie erhält pro Vertragsumstellung eine Prämie von € 4.\n\nBerechnen Sie die pro Woche zu erwartende Prämie."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "praemie",
            "value": 280,
            "tol": 1e-9,
            "unit": "€"
          }
        ]
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "200\\cdot 0{,}35\\cdot 4=280"
            }
          ],
          "result": [
            {
              "t": "text",
              "v": "Die pro Woche zu erwartende Prämie beträgt € 280."
            }
          ],
          "note": "c1) Ein Punkt für das richtige Berechnen."
        }
      ]
    },
    {
      "id": "2025-wt-t2-01-c2",
      "label": "c2",
