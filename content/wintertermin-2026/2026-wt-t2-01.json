      ],
      "prompt": [
        {
          "t": "text",
          "v": "In der nachstehenden Abbildung ist der Querschnitt des Schwimmbeckens im neuen Hallenbad modellhaft dargestellt."
        },
        {
          "t": "fig",
          "src": "assets/pdf/wintertermin-2026/fig/2026-wt-t2-01-b-q.png",
          "alt": "Modellhafter Querschnitt des Schwimmbeckens: oben die waagrechte Strecke a; links die Tiefe h1, rechts die Tiefe h2; links ein waagrechter Boden der Länge x, dann ein unter dem Winkel α abfallender Beckenboden zu einem rechten Bodenstück der Länge x."
        },
        {
          "t": "text",
          "v": "Stellen Sie eine Formel zur Berechnung des Winkels α auf. Verwenden Sie dabei a, x, h1 und h2."
        },
        {
          "t": "math",
          "v": "\\alpha="
        }
      ],
      "figures": [],
      "answer": {
        "kind": "expression",
        "canonical": "\\arctan\\left(\\frac{h2-h1}{a-2\\cdot x}\\right)",
        "vars": [
          "a",
          "x",
          "h1",
          "h2"
        ],
        "checker": "cas"
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "result": [
            {
              "t": "math",
              "v": "\\alpha=\\arctan\\!\\left(\\frac{h_2-h_1}{a-2\\cdot x}\\right)"
            }
          ],
          "note": "b1) Ein Punkt für das richtige Aufstellen der Formel für α."
        }
      ]
    },
    {
