      "figures": [],
      "answer": {
        "kind": "expression",
        "canonical": "76\\cdot\\left(\\frac{132}{76}\\right)^{\\frac{t}{40}}",
        "vars": [
          "t"
        ],
        "checker": "cas"
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "a=f(0)=76"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "b=\\sqrt[40]{\\tfrac{132}{76}}=1{,}0138\\ldots"
            }
          ],
          "result": [
            {
              "t": "math",
              "v": "f(t)=76\\cdot 1{,}0138\\ldots^{\\,t}"
            }
          ],
          "note": "a1) Ein Punkt für das richtige Aufstellen der Funktionsgleichung von f."
        }
