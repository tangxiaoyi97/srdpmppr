  "figures": [],
  "parts": [
    {
      "id": "2020-ht-t2-02-a1",
      "label": "a1",
      "format": "",
      "competencies": [],
      "externalRefs": [],
      "prompt": [
        {
          "t": "text",
          "v": "Auf einem Kreuzfahrtschiff mit 2 000 Passagieren erkranken ab dem Zeitpunkt t = 0, zu dem noch kein Passagier erkrankt ist, jeden Tag 5 % der noch nicht erkrankten Passagiere. Dabei ist Nₜ die Anzahl der erkrankten Passagiere zum Zeitpunkt t mit t in Tagen.\n\nGeben Sie eine Differenzengleichung für Nₜ₊₁ an."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "open",
        "rubric": [
          {
            "t": "text",
            "v": "Eine richtige Differenzengleichung, z. B.: "
          },
          {
            "t": "math",
            "v": "N_{t+1}-N_{t}=0{,}05\\cdot(2\\,000-N_{t})\\ \\text{mit}\\ N_0=0"
          },
          {
            "t": "text",
            "v": ". „N₀ = 0“ muss nicht angegeben sein. Äquivalente Gleichungen sind als richtig zu werten."
          }
        ],
        "grader": "ai"
      },
      "scoring": {
        "mode": "rubric",
        "criteria": [
          {
            "desc": "Ein Punkt für eine richtige Differenzengleichung, wobei „N0 = 0“ nicht angegeben sein muss. Äquivalente Gleichungen sind als richtig zu werten.",
            "points": 1
          }
        ]
      },
      "points": 1,
      "solution": [
        {
          "result": [
            {
              "t": "math",
              "v": "N_{t+1}-N_{t}=0{,}05\\cdot(2\\,000-N_{t})\\ \\text{mit}\\ N_0=0"
            }
          ],
          "note": "a1) Ein Punkt für eine richtige Differenzengleichung, wobei „N0 = 0“ nicht angegeben sein muss. Äquivalente Gleichungen sind als richtig zu werten."
        }
      ]
    },
    {
      "id": "2020-ht-t2-02-a2",
      "label": "a2",
      "format": "",
      "competencies": [],
      "externalRefs": [],
      "prompt": [
        {
          "t": "text",
          "v": "Ermitteln Sie, nach wie vielen Tagen erstmals mehr als 25 % der Passagiere erkrankt sind."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "tage",
            "value": 5.5,
            "tol": 0.5,
            "unit": "Tage"
          }
        ]
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "text",
              "v": "mögliche Vorgehensweise:\n"
            },
            {
              "t": "math",
              "v": "N_{t+1}=N_{t}+0{,}05\\cdot(2\\,000-N_{t})=0{,}95\\cdot N_{t}+100"
            },
            {
              "t": "text",
              "v": "\nFür N₀ = 0 ist N₆ > 500."
            }
          ],
          "result": [
            {
              "t": "text",
              "v": "Nach 6 Tagen sind erstmals mehr als 25 % der Passagiere erkrankt."
            }
          ],
          "note": "a2) Ein Punkt für die richtige Lösung. Toleranzintervall: [5; 6]"
        }
      ]
    },
    {
      "id": "2020-ht-t2-02-b1",
      "label": "b1",
      "format": "",
      "competencies": [],
      "externalRefs": [],
      "prompt": [
        {
          "t": "text",
          "v": "Die Differenzengleichung Nₜ₊₁ − Nₜ = r · (S − Nₜ) lässt sich in der Form Nₜ₊₁ = a · Nₜ + b mit a, b ∈ ℝ darstellen.\n\nDrücken Sie r und S durch a und b aus."
        },
        {
          "t": "math",
          "v": "r=\\qquad\\qquad S="
        }
      ],
      "figures": [],
      "answer": {
        "kind": "open",
        "rubric": [
          {
            "t": "text",
            "v": "Die beiden richtigen Terme: "
          },
          {
            "t": "math",
            "v": "r=1-a"
          },
          {
            "t": "text",
            "v": " und "
          },
          {
            "t": "math",
            "v": "S=\\frac{b}{r}=\\frac{b}{1-a}"
          },
          {
            "t": "text",
            "v": ". Andere Schreibweisen sind als richtig zu werten."
          }
        ],
        "grader": "ai"
      },
      "scoring": {
        "mode": "rubric",
        "criteria": [
          {
            "desc": "Ein Punkt für die beiden richtigen Lösungen. Andere Schreibweisen der Lösungen sind ebenfalls als richtig zu werten.",
            "points": 1
          }
        ]
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "N_{t+1}=(1-r)\\cdot N_{t}+r\\cdot S\\ \\Rightarrow\\ a=1-r\\ \\text{und}\\ b=r\\cdot S"
            }
          ],
          "result": [
            {
              "t": "math",
              "v": "r=1-a;\\quad S=\\frac{b}{r}=\\frac{b}{1-a}"
            }
          ],
          "note": "b1) Ein Punkt für die beiden richtigen Lösungen. Andere Schreibweisen der Lösungen sind ebenfalls als richtig zu werten."
        }
      ]
    },
    {
      "id": "2020-ht-t2-02-b2",
      "label": "b2",
      "format": "",
      "competencies": [],
      "externalRefs": [],
      "prompt": [
        {
          "t": "text",
          "v": "Zur Entwicklung eines neuen Impfstoffs wird das Wachstum einer Bakterienkultur in einer Petrischale untersucht.\n\nIn der nachstehenden Tabelle ist der Inhalt Nₜ (in cm²) derjenigen Fläche angeführt, die von der Bakterienkultur zum Zeitpunkt t (in h) bedeckt wird."
        },
        {
          "t": "fig",
          "src": "assets/pdf/haupttermin-2020/fig/2020-ht-t2-02-b-tab.png",
          "alt": "Tabelle: t in h | Nₜ in cm² — 0 | 5,00; 1 | 9,80; 2 | 14,41."
        },
        {
          "t": "text",
          "v": "Ermitteln Sie a und b mithilfe der in der obigen Tabelle angegebenen Werte."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "a",
            "label": "a",
            "value": 0.96,
            "tol": 0.005
          },
          {
            "id": "b",
            "label": "b",
            "value": 5,
            "tol": 0.01
          }
        ]
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "text",
              "v": "mögliche Vorgehensweise:\n"
            },
            {
              "t": "math",
              "v": "\\text{I: } 9{,}8=5\\cdot a+b"
            },
            {
              "t": "text",
              "v": "\n"
            },
            {
              "t": "math",
              "v": "\\text{II: } 14{,}41=9{,}8\\cdot a+b"
            }
          ],
          "result": [
            {
              "t": "math",
              "v": "a=0{,}960\\ldots\\approx 0{,}96\\ \\text{und}\\ b=4{,}997\\ldots\\approx 5{,}00"
            }
          ],
          "note": "b2) Ein Punkt für die Angabe der beiden richtigen Werte."
        }
      ]
    },
    {
      "id": "2020-ht-t2-02-c1",
      "label": "c1",
      "format": "",
      "competencies": [
        {
          "code": "FA 1.7",
          "description": "Eigenschaften von Funktionen erkennen, benennen und im Kontext deuten können",
          "source": "printed",
          "verifiedAt": "2026-07-01"
        }
      ],
      "externalRefs": [],
      "prompt": [
        {
          "t": "text",
          "v": "Ein Pharmaunternehmen bringt einen neuen Impfstoff auf den Markt. In der ersten Woche nach der Markteinführung haben bereits 15 000 Personen den Impfstoff gekauft.\n\nDie Anzahl f(t) derjenigen Personen, die den Impfstoff innerhalb von t Wochen nach der Markteinführung gekauft haben, lässt sich modellhaft durch die Funktion f mit"
        },
        {
          "t": "math",
          "v": "f(t)=1\\,000\\,000\\cdot\\left(1-e^{-k\\cdot t}\\right)"
        },
        {
          "t": "text",
          "v": "beschreiben (k ∈ ℝ⁺).\n\nBerechnen Sie k."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "k",
            "label": "k",
            "value": 0.0151,
            "tol": 0.0001,
            "unit": "pro Woche"
          }
        ]
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "15\\,000=1\\,000\\,000\\cdot\\left(1-e^{-k\\cdot 1}\\right)\\ \\Rightarrow\\ k=0{,}01511\\ldots\\ \\Rightarrow\\ k\\approx 0{,}0151\\ \\text{pro Woche}"
            }
          ],
          "result": [
            {
              "t": "math",
              "v": "k\\approx 0{,}0151\\ \\text{pro Woche}"
            }
          ],
          "note": "c1) Ein Ausgleichspunkt für die richtige Lösung, wobei die Einheit „pro Woche“ nicht angegeben sein muss. Grundkompetenz: FA 1.7"
        }
      ]
    },
    {
      "id": "2020-ht-t2-02-c2",
      "label": "c2",
      "format": "",
      "competencies": [],
      "externalRefs": [],
      "prompt": [
        {
          "t": "text",
          "v": "Ermitteln Sie denjenigen Zeitpunkt t₀, zu dem erstmals 500 000 Personen diesen Impfstoff gekauft haben."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "t0",
            "label": "t₀",
            "value": 46,
            "tol": 1,
            "unit": "Wochen"
          }
        ]
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "500\\,000=1\\,000\\,000\\cdot\\left(1-e^{-k\\cdot t_0}\\right)\\ \\Rightarrow\\ t_0=45{,}8\\ldots\\ \\Rightarrow\\ t_0\\approx 46\\ \\text{Wochen}"
            }
          ],
          "result": [
            {
              "t": "math",
              "v": "t_0\\approx 46\\ \\text{Wochen}"
            }
          ],
          "note": "c2) Ein Punkt für die richtige Lösung, wobei die Einheit „Woche“ nicht angegeben sein muss. (Die Lösung kann je nach Rundung von k von der angegebenen Lösung abweichen.)"
        }
      ]
    }
  ],
  "externalRefs": [],
  "prompt": [
    {
      "t": "text",
      "v": "Im Folgenden werden Wachstumsmodelle betrachtet.\n\nDie nachstehende Differenzengleichung beschreibt ein Wachstum."
    },
    {
      "t": "math",
      "v": "N_{t+1}-N_{t}=r\\cdot(S-N_{t})"
    },
    {
      "t": "text",
      "v": "Nₜ ... Bestand zum Zeitpunkt t\nr ... Wachstumskonstante, r ∈ ℝ⁺\nS ... (obere) Kapazitätsgrenze"
    }
  ]
