            {
              "t": "math",
              "v": "\\vec{g}\\cdot\\vec{AB}=\\begin{pmatrix} 1 \\\\ 1 \\end{pmatrix}\\cdot\\begin{pmatrix} 6 \\\\ -6 \\end{pmatrix}=6-6=0"
