      "prompt": [
        {
          "t": "text",
          "v": "Ein bestimmter Satellit bewegt sich mit der Geschwindigkeit v = 7 500 m/s auf seiner Umlaufbahn. Der Zusammenhang zwischen seiner Geschwindigkeit und dem Radius seiner Umlaufbahn wird durch die nachstehende Gleichung angegeben."
        },
        {
          "t": "math",
          "v": "v=\\sqrt{\\dfrac{G\\cdot M}{r}}"
        },
        {
          "t": "text",
          "v": "v ... Geschwindigkeit des Satelliten in m/s\nG = 6,67 ∙ 10⁻¹¹ ... allgemeine Gravitationskonstante in m³/(kg ∙ s²)\nM = 5,97 ∙ 10²⁴ ... Masse der Erde in kg\nr ... Radius der Umlaufbahn des Satelliten in m\n\nBerechnen Sie den Radius r der Umlaufbahn dieses Satelliten."
        },
        {
          "t": "math",
          "v": "r=\\underline{\\hphantom{xxxxx}}\\ \\text{m}"
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "r",
            "label": "r",
            "value": 7079093.3,
            "tol": 1000,
            "unit": "m"
          }
        ]
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "7\\,500=\\sqrt{\\dfrac{6{,}67\\cdot 10^{-11}\\cdot 5{,}97\\cdot 10^{24}}{r}}"
            }
          ],
          "result": [
