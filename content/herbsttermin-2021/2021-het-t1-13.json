      ],
      "prompt": [
        {
          "t": "text",
          "v": "Die differenzierbare Funktion T ordnet der Zeit t ≥ 0 die Temperatur T(t) eines Körpers zu (t in h, T(t) in °C).\n\nDie nachstehende Abbildung zeigt den Graphen dieser Funktion T."
        },
        {
          "t": "fig",
