    {
      "id": "2021-het-t2-02-b1",
      "label": "b1",
      "format": "",
      "competencies": [],
      "externalRefs": [],
      "prompt": [
        {
          "t": "text",
          "v": "Ein bestimmter gekühlter Wein in einem Weinglas hat eine Anfangstemperatur von T₀ = 5 °C.\nDie Umgebungstemperatur beträgt konstant U = 25 °C.\nDie Temperatur des Weines wird in regelmäßigen Abständen gemessen. Zum Zeitpunkt t hat sie den Wert Tₜ.\n\nPro Minute nimmt die Temperatur des Weines um 8 % der Differenz zwischen der Umgebungstemperatur U und der zum Zeitpunkt t gemessenen Temperatur des Weines Tₜ zu. Die Temperatur des Weines steigt dabei auf den Wert Tₜ₊₁.\n\nErgänzen Sie die nachstehende Differenzengleichung für diesen Erwärmungsvorgang."
        },
        {
          "t": "math",
          "v": "T_{t+1}=T_t+\\boxed{\\phantom{0}}\\quad\\text{mit}\\quad T_0=5"
        }
      ],
      "figures": [],
      "answer": {
        "kind": "expression",
        "canonical": "0.08\\cdot(25-T_t)",
        "vars": [
          "T_t"
        ],
        "checker": "cas"
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "result": [
            {
              "t": "math",
              "v": "T_{t+1}=T_t+0{,}08\\cdot(25-T_t)"
            }
          ],
          "note": "b1) Ein Punkt für das richtige Ergänzen der Differenzengleichung."
        }
      ]
    },
    {
      "id": "2021-het-t2-02-b2",
      "label": "b2",
      "format": "",
      "competencies": [],
      "externalRefs": [],
      "prompt": [
