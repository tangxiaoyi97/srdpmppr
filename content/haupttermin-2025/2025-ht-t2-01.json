      "prompt": [
        {
          "t": "text",
          "v": "Dieses Blumenbeet soll so umgestaltet werden, dass es die Form eines Rechtecks mit der Länge 6 m und der Breite c (in m) hat (siehe nachstehende Abbildung). Der Flächeninhalt des Blumenbeets soll durch die Umgestaltung nicht verändert werden."
        },
        {
          "t": "fig",
          "src": "assets/pdf/haupttermin-2025/fig/2025-ht-t2-01-a2-q.png",
          "alt": "Abbildung: das umgestaltete Blumenbeet als Rechteck der Länge 6 m (von x = -3 bis x = 3) und der Breite c."
        },
        {
          "t": "text",
          "v": "\n\nStellen Sie mithilfe von f eine Formel zur Berechnung von c auf.\n\n"
        },
        {
          "t": "math",
          "v": "c="
        }
      ],
      "figures": [],
      "answer": {
        "kind": "open",
