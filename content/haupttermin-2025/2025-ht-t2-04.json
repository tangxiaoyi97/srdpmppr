        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "v+w=300"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "0{,}42\\cdot v+0{,}3\\cdot w=0{,}35\\cdot 300"
            }
          ],
          "result": [
            {
              "t": "math",
              "v": "v=125,\\quad w=175"
