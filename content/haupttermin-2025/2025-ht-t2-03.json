      "prompt": [
        {
          "t": "text",
          "v": "Der Weg zum Basislager beginnt beim Flughafen Lukla in Nepal.\n\nModellhaft wird angenommen, dass die Landebahn des Flughafens Lukla eine konstante Steigung von 11,7 % hat. Die Landebahn überwindet einen Höhenunterschied von 61 m (siehe nachstehende nicht maßstabgetreue Abbildung)."
        },
        {
          "t": "fig",
          "src": "assets/pdf/haupttermin-2025/fig/2025-ht-t2-03-a-q.png",
          "alt": "Nicht maßstabgetreue Abbildung: schräge Landebahn (Hypotenuse) mit Länge der Landebahn und vertikalem Höhenunterschied von 61 m."
        },
        {
          "t": "text",
          "v": "\n\nBerechnen Sie die Länge der Landebahn."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "x",
            "label": "Länge der Landebahn",
            "value": 524.9,
            "tol": 1.5,
            "unit": "m"
          }
        ]
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "\\tan(\\alpha)=0{,}117 \\Rightarrow \\alpha=6{,}673\\ldots^{\\circ}"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "\\sin(6{,}673\\ldots^{\\circ})=\\dfrac{61}{x} \\Rightarrow x=524{,}9\\ldots"
            }
          ],
          "result": [
            {
              "t": "text",
              "v": "Die Landebahn hat eine Länge von rund 525 m."
            }
          ],
          "note": "Ein Punkt für das richtige Berechnen der Länge der Landebahn."
        }
      ]
    },
