      "prompt": [
        {
          "t": "text",
          "v": "Für weitere Eckpunkte R, S und T des Quaders gilt:"
        },
        {
          "t": "math",
          "v": "R=E+\\overrightarrow{AB}"
        },
        {
          "t": "math",
          "v": "S=A+\\overrightarrow{AE}+\\overrightarrow{BC}"
        },
        {
          "t": "math",
          "v": "T=E+\\overrightarrow{BC}-\\overrightarrow{AE}"
        },
        {
          "t": "text",
          "v": "Beschriften Sie in der oben stehenden Abbildung klar erkennbar die Eckpunkte R, S und T!"
        }
      ],
      "answer": {
        "kind": "open",
        "rubric": [
          {
            "t": "text",
            "v": "In der Abbildung sind die drei Eckpunkte R, S und T des Quaders richtig zu beschriften: R liegt schräg oberhalb von B (R = E + AB), S liegt schräg oberhalb von C (S = A + AE + BC) und T ist der dem Punkt B gegenüberliegende obere Eckpunkt (T = E + BC − AE)."
          }
        ],
        "grader": "ai"
