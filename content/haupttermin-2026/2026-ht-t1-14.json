      "t": "text",
      "v": "\n"
    },
    {
      "t": "math",
      "v": "b=\\lim_{z\\to x_2}\\dfrac{f(z)-f(x_2)}{z-x_2}"
    },
    {
      "t": "text",
      "v": "\n"
    },
    {
      "t": "math",
      "v": "c=\\lim_{\\Delta x\\to 0}\\dfrac{f(x_2+\\Delta x)-f(x_2)}{\\Delta x}"
