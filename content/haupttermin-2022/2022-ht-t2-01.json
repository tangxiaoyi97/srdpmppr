      "prompt": [
        {
          "t": "text",
          "v": "Der empfohlene Reifendruck eines Fahrradreifens sinkt mit zunehmender Breite des Reifens. Für einen empfohlenen Reifendruck von 2 bar bis 9 bar kann der empfohlene Reifendruck näherungsweise durch die Funktion p beschrieben werden."
        },
        {
          "t": "math",
          "v": "p(x)=19{,}1\\cdot e^{-0{,}0376\\cdot x}"
        },
        {
          "t": "text",
          "v": "x ... Breite des Reifens in mm\np(x) ... empfohlener Reifendruck bei der Breite x in bar\n\nErmitteln Sie das größtmögliche Intervall für die Breite des Reifens, für das sich ein empfohlener Reifendruck von 2 bar bis 9 bar ergibt."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "interval",
        "lower": 20,
        "upper": 60,
        "lowerClosed": true,
        "upperClosed": true
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "p(x)=9\\ \\Rightarrow\\ x=20{,}0\\ldots"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "p(x)=2\\ \\Rightarrow\\ x=60{,}0\\ldots"
            }
          ],
          "result": [
            {
              "t": "text",
              "v": "größtmögliches Intervall: "
            },
            {
              "t": "math",
              "v": "[20{,}0\\ldots;\\,60{,}0\\ldots]"
            }
          ],
          "note": "b1) Ein Punkt für das richtige Ermitteln des größtmöglichen Intervalls."
        }
      ]
