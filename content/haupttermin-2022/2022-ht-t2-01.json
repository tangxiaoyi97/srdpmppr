        }
      ],
      "prompt": [
        {
          "t": "text",
          "v": "Berechnen Sie die Beschleunigung zum Zeitpunkt t = 1. Geben Sie auch die zugehörige Einheit an."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "a",
            "label": "a(1)",
            "value": -0.16,
            "tol": 1e-9,
            "unit": "km/h²"
          }
        ]
      },
      "scoring": {
        "mode": "rubric",
        "criteria": [
          {
            "desc": "Ein halber Punkt für das richtige Berechnen der Beschleunigung.",
            "points": 0.5
          },
          {
            "desc": "Ein halber Punkt für das Angeben der richtigen Einheit.",
            "points": 0.5
          }
        ]
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "a(t)=v'(t)=-0{,}16\\cdot t"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "v'(1)=-0{,}16"
            }
          ],
          "result": [
            {
              "t": "text",
              "v": "Die Beschleunigung zum Zeitpunkt t = 1 beträgt –0,16 km/h²."
            }
          ],
          "note": "a2) Ein halber Punkt für das richtige Berechnen der Beschleunigung, ein halber Punkt für das Angeben der richtigen Einheit."
        }
      ]
    },
