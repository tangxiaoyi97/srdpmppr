        }
      ],
      "prompt": [
        {
          "t": "text",
          "v": "Bettina macht eine 2-stündige Fahrradtour. Ihre Geschwindigkeit kann dabei näherungsweise durch die Funktion v beschrieben werden."
        },
        {
          "t": "math",
          "v": "v(t)=-0{,}08\\cdot t^{2}+16\\quad\\text{mit}\\ 0\\le t\\le 2"
        },
        {
          "t": "text",
          "v": "t ... Zeit in h mit t = 0 für den Beginn der Fahrradtour\nv(t) ... Geschwindigkeit zum Zeitpunkt t in km/h\n\nBerechnen Sie die Zeitdauer, die Bettina für die ersten 10 km dieser Fahrradtour benötigt."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "t1",
            "label": "t₁",
            "value": 0.62,
            "tol": 0.05,
            "unit": "h"
          }
        ]
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "\\int_{0}^{t_1} v(t)\\,dt=10"
            },
            {
              "t": "text",
              "v": "\nBerechnung mittels Technologieeinsatz:\n"
            },
            {
              "t": "math",
              "v": "t_1=0{,}62\\ldots"
            }
          ],
          "result": [
            {
              "t": "text",
              "v": "Bettina benötigt für die ersten 10 km rund 0,6 h."
            }
          ],
          "note": "a1) Ein Punkt für das richtige Berechnen der Zeitdauer."
        }
      ]
    },
    {
      "id": "2022-ht-t2-01-a2",
      "label": "a2",
      "format": "Offenes Antwortformat",
      "competencies": [
        {
          "code": "AN 1.3",
          "description": "den Differenzen- und Differenzialquotienten in verschiedenen Kontexten deuten und entsprechende Sachverhalte durch den Differenzen- bzw. Differenzialquotienten beschreiben können",
          "source": "aufgabenpool",
          "verifiedAt": "2026-06-30"
        }
      ],
      "externalRefs": [
        {
          "system": "aufgabenpool",
