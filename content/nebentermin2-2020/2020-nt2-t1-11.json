      "solution": [
        {
          "steps": [
            {
              "t": "text",
              "v": "mögliche Vorgehensweise:\n"
            },
            {
              "t": "math",
              "v": "2\\cdot K_0=K_0\\cdot 1{,}01^{n}"
            },
            {
              "t": "text",
              "v": "\n"
            },
            {
              "t": "math",
              "v": "2=1{,}01^{n}"
            },
            {
              "t": "text",
              "v": "\n"
            },
            {
              "t": "math",
              "v": "\\ln(2)=\\ln(1{,}01)\\cdot n"
            },
            {
              "t": "text",
              "v": "\n"
            },
            {
              "t": "math",
              "v": "n=\\dfrac{\\ln(2)}{\\ln(1{,}01)}=69{,}66\\ldots\\approx 69{,}7"
            }
          ],
          "result": [
            {
              "t": "text",
              "v": "Das Kapital K₀ verdoppelt sich nach ca. 69,7 Jahren."
            }
          ],
          "note": "Ein Punkt für die richtige Lösung, wobei die Einheit „Jahr“ nicht angeführt sein muss. Toleranzintervall: [69 Jahre; 70 Jahre]"
        }
      ],
