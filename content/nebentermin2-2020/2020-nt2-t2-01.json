      "prompt": [
        {
          "t": "text",
          "v": "Die Funktion B hat genau eine positive Extremstelle t₁.\n\nBestimmen Sie t₁ in Abhängigkeit von k und c."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "expression",
        "canonical": "k/c",
        "vars": [
          "k",
          "c"
        ],
        "checker": "cas"
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "text",
              "v": "mögliche Vorgehensweise:\n"
            },
            {
              "t": "math",
              "v": "B'(t)=b\\cdot(k-c\\cdot t)\\cdot e^{\\,k\\cdot t-\\frac{c}{2}\\cdot t^{2}}"
            },
            {
              "t": "text",
              "v": "\n"
            },
            {
              "t": "math",
              "v": "B'(t_1)=0"
            },
            {
              "t": "text",
              "v": "\n"
            },
            {
              "t": "math",
              "v": "k-c\\cdot t_1=0"
            }
          ],
          "result": [
            {
              "t": "math",
              "v": "t_1=\\dfrac{k}{c}"
            }
          ],
          "note": "a1) Ein Punkt für die richtige Lösung. Andere Schreibweisen der Lösung sind ebenfalls als richtig zu werten."
        }
      ]
