          "verifiedAt": "2026-06-30"
        }
      ],
      "prompt": [
        {
          "t": "text",
          "v": "In der nachstehenden Abbildung ist ein Firmenlogo grau markiert dargestellt."
        },
        {
          "t": "fig",
          "src": "assets/pdf/herbsttermin-2022/fig/2022-het-t2-01-a.png",
          "alt": "Koordinatensystem (f(x), g(x) in cm) mit einem grau markierten Firmenlogo; die untere Begrenzungslinie ist ein Teil des Graphen von f, die obere ein Teil des Graphen von g."
        },
        {
          "t": "text",
          "v": "Die untere Begrenzungslinie wird durch einen Teil des Graphen der Funktion f beschrieben:"
        },
        {
          "t": "math",
          "v": "f(x)=\\tfrac{1}{8}\\cdot x^{2}-2"
        },
        {
          "t": "text",
          "v": "Die obere Begrenzungslinie wird durch einen Teil des Graphen der Funktion g beschrieben:"
        },
        {
          "t": "math",
          "v": "g(x)=a\\cdot(x^{3}-16\\cdot x)\\quad\\text{mit}\\ a\\in\\mathbb{R}"
        },
        {
          "t": "text",
          "v": "An der Stelle x = 4 haben f und g die gleiche Steigung.\n\nBerechnen Sie den Parameter a."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "a",
            "label": "a",
            "value": 0.03125,
            "tol": 1e-9
          }
        ]
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "f'(x)=\\tfrac{x}{4}"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "f'(4)=1"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "g'(x)=a\\cdot(3\\cdot x^{2}-16)"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "g'(4)=32\\cdot a"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "32\\cdot a=1"
            }
          ],
          "result": [
            {
              "t": "math",
              "v": "a=\\tfrac{1}{32}"
            }
          ],
          "note": "a1) Ein Punkt für das richtige Berechnen von a."
        }
      ]
    },
    {
      "id": "2022-het-t2-01-a2",
      "label": "a2",
      "format": "Offenes Antwortformat",
      "competencies": [
