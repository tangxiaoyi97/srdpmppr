      "prompt": [
        {
          "t": "text",
          "v": "Das Logo eines Autoherstellers hat die Form eines regelmäßigen Fünfecks (siehe nachstehende nicht maßstabgetreue Abbildung)."
        },
        {
          "t": "fig",
          "src": "assets/pdf/herbsttermin-2022/fig/2022-het-t2-01-b.png",
          "alt": "Nicht maßstabgetreue Abbildung eines regelmäßigen Fünfecks mit Seitenlänge s; vom Mittelpunkt aus zwei Radien r, die einen Mittelpunktswinkel von 72° einschließen."
        },
        {
          "t": "text",
          "v": "Berechnen Sie für r = 3 cm den Umfang u dieses regelmäßigen Fünfecks."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "u",
            "label": "u",
            "value": 17.63,
            "tol": 0.05,
            "unit": "cm"
          }
        ]
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "u=5\\cdot 2\\cdot 3\\cdot\\sin(36^\\circ)=17{,}63\\ldots"
            }
          ],
          "result": [
