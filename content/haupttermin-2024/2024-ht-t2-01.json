          "license": "CC-BY-4.0",
          "verifiedAt": "2026-06-30"
        }
      ],
      "prompt": [
        {
          "t": "text",
          "v": "Paul schießt einen Pfeil auf eine Figur. Die Flugbahn der Pfeilspitze vom Start im Punkt S zum Ziel im Punkt Z kann durch die Gerade g modelliert werden.\n\nEs gilt: "
        },
        {
          "t": "math",
          "v": "S=(0\\mid 0\\mid 1{,}8),\\ Z=(-5\\mid 7\\mid 8{,}5)"
        },
        {
          "t": "text",
          "v": "\n\nStellen Sie eine Gleichung von g in Parameterdarstellung auf."
        },
        {
          "t": "math",
          "v": "g\\!:\\ X="
        }
      ],
      "figures": [],
      "answer": {
        "kind": "open",
        "rubric": [
          {
            "t": "math",
            "v": "g\\!:\\ X=\\begin{pmatrix} 0 \\\\ 0 \\\\ 1{,}8 \\end{pmatrix}+t\\cdot\\begin{pmatrix} -5 \\\\ 7 \\\\ 6{,}7 \\end{pmatrix}\\ \\text{mit}\\ t\\in\\mathbb{R}"
          },
          {
            "t": "text",
            "v": ". Die Angabe von „"
          },
          {
            "t": "math",
            "v": "t\\in\\mathbb{R}"
          },
          {
            "t": "text",
            "v": "“ ist für die Punktevergabe nicht erforderlich. Auch jede dazu äquivalente Parameterdarstellung ist richtig."
          }
        ],
        "grader": "ai"
      },
      "scoring": {
        "mode": "rubric",
        "criteria": [
          {
            "desc": "a1) Ein Punkt für das richtige Aufstellen der Gleichung von g.",
            "points": 1
          }
        ]
      },
      "points": 1,
      "solution": [
        {
          "result": [
            {
              "t": "math",
              "v": "g\\!:\\ X=\\begin{pmatrix} 0 \\\\ 0 \\\\ 1{,}8 \\end{pmatrix}+t\\cdot\\begin{pmatrix} -5 \\\\ 7 \\\\ 6{,}7 \\end{pmatrix}\\ \\text{mit}\\ t\\in\\mathbb{R}"
            }
          ],
          "note": "a1) Ein Punkt für das richtige Aufstellen der Gleichung von g. Die Angabe von „t ∈ ℝ“ ist für die Punktevergabe nicht erforderlich."
        }
      ]
    },
    {
      "id": "2024-ht-t2-01-b1",
      "label": "b1",
      "format": "Halboffenes Antwortformat",
      "competencies": [
        {
          "code": "AG 4.1",
          "description": "Definitionen von Sinus, Cosinus und Tangens im rechtwinkeligen Dreieck kennen und zur Auflösung rechtwinkeliger Dreiecke einsetzen können",
          "source": "aufgabenpool",
          "verifiedAt": "2026-06-30"
        }
      ],
      "externalRefs": [
        {
          "system": "aufgabenpool",
          "id": "2_137b",
          "baseId": "2_137",
          "url": "https://www.aufgabenpool.at/amn/Typ-2/916/2_137_srdp_ma_Bogenschie%C3%9Fen_PT1_24.pdf",
          "license": "CC-BY-4.0",
          "verifiedAt": "2026-06-30"
        }
      ],
      "prompt": [
        {
          "t": "text",
          "v": "Lara sieht eine bestimmte Figur unter dem Sehwinkel α. In der nachstehenden nicht maßstabgetreuen Abbildung ist der Zusammenhang zwischen dem Sehwinkel α, der Entfernung r und der Größe h dargestellt."
        },
        {
          "t": "fig",
          "src": "assets/pdf/haupttermin-2024/fig/2024-ht-t2-01-b.png",
          "alt": "Nicht maßstabgetreue Abbildung: vom Auge ausgehender Sehwinkel α (halbiert in α/2), Entfernung r zur Figur, Größe h der Figur (rechtwinkeliges Dreieck)."
        },
        {
          "t": "text",
          "v": "Stellen Sie unter Verwendung von α und r eine Formel zur Berechnung von h auf."
        },
        {
          "t": "math",
          "v": "h="
        }
      ],
      "figures": [],
      "answer": {
        "kind": "expression",
        "canonical": "2*r*tan(alpha/2)",
        "vars": [
          "r",
          "alpha"
        ],
        "checker": "cas"
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "result": [
            {
              "t": "math",
              "v": "h=2\\cdot r\\cdot\\tan\\!\\left(\\tfrac{\\alpha}{2}\\right)"
            }
          ],
          "note": "b1) Ein Punkt für das richtige Aufstellen der Formel zur Berechnung von h."
        }
      ]
    },
