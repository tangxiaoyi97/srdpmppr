      "prompt": [
        {
          "t": "text",
          "v": "Die Gesamtkosten in Abhängigkeit von der Zeit lassen sich näherungsweise für das Elektroauto durch die lineare Funktion e: [0; 60] → ℝ⁺ und für das Auto mit Verbrennungsmotor durch die lineare Funktion m: [0; 60] → ℝ⁺ beschreiben (t in Monaten mit t = 0 für den Zeitpunkt des Kaufes, e(t), m(t) in €).\nDer Graph von m ist in der nachstehenden Abbildung dargestellt."
        },
        {
          "t": "fig",
          "src": "assets/pdf/herbsttermin-2025/fig/2025-het-t2-01-a-q.png",
          "alt": "Koordinatensystem mit e(t), m(t) in € (14 000 bis 32 000) über t in Monaten (0 bis 60); der Graph der Geraden m verläuft vom Wert 16 000 bei t = 0 ansteigend."
        },
        {
          "t": "text",
          "v": "Die Kosten für den Erwerb des Elektroautos betragen € 18.000, die Ausgaben pro Monat betragen € 160.\n\nErmitteln Sie, nach wie vielen Monaten die Gesamtkosten für beide Autos gleich hoch sind."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "t",
            "label": "t",
            "value": 25,
            "tol": 2,
            "unit": "Monate"
          }
        ]
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "m(t)=16\\,000+\\tfrac{12\\,000}{50}\\cdot t"
            },
            {
              "t": "text",
              "v": "; "
            },
            {
              "t": "math",
              "v": "e(t)=18\\,000+160\\cdot t"
            },
            {
              "t": "text",
              "v": "\n"
            },
            {
              "t": "math",
              "v": "m(t)=e(t)\\ \\Rightarrow\\ t=25"
            }
          ],
          "result": [
            {
              "t": "text",
              "v": "Nach 25 Monaten sind die Gesamtkosten für beide Autos gleich hoch. Toleranzbereich: [23; 27]."
            }
          ],
          "note": "a1) Ein Punkt für das richtige Ermitteln der Anzahl der Monate."
        }
      ]
    },
