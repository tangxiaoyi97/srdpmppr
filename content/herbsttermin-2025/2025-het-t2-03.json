            "t": "math",
            "v": "n\\cdot b+(n-1)\\cdot a=3\\,400"
          },
          {
            "t": "text",
            "v": " (Länge in cm; n Bretter der Breite b cm und n − 1 Abstände der Breite a cm ergeben 34 m = 3 400 cm)."
          }
        ],
        "grader": "ai"
      },
      "scoring": {
