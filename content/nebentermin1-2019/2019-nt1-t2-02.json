      "prompt": [
        {
          "t": "text",
          "v": "Für den Verkaufspreis p kann der Erlös in Abhängigkeit von der Produktionsmenge x durch eine lineare Funktion E mit E(x) = p · x beschrieben werden (E(x) in GE, x in ME, p in GE/ME). Dabei wird vorausgesetzt, dass gleich viele Mengeneinheiten verkauft wie produziert werden."
        },
        {
          "t": "text",
          "v": "Bestimmen Sie p so, dass der maximale Gewinn bei einem Verkauf von 600 ME erzielt wird."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "p",
            "value": 0.2045,
            "tol": 0.005,
            "unit": "GE/ME"
          }
        ]
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "text",
              "v": "mögliche Vorgehensweise:\n"
            },
            {
              "t": "math",
              "v": "G(x)=E(x)-K(x)"
            },
            {
              "t": "math",
              "v": "G'(x)=p-K'(x)"
            },
            {
              "t": "math",
              "v": "G'(600)=p-K'(600)=0\\ \\Rightarrow\\ p=0{,}2045\\ \\text{GE/ME}"
            }
          ],
          "result": [
            {
              "t": "math",
              "v": "p=0{,}2045\\ \\text{GE/ME}"
            }
          ],
