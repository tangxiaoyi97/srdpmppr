      "solution": [
        {
          "steps": [
            {
              "t": "text",
              "v": "mögliche Vorgehensweise:\n"
            },
            {
              "t": "math",
              "v": "\\bar K(x)=8\\cdot 10^{-7}\\cdot x^{2}-7{,}5\\cdot 10^{-4}\\cdot x+0{,}2405+\\dfrac{42}{x}"
            },
            {
              "t": "math",
              "v": "\\bar K'(x)=16\\cdot 10^{-7}\\cdot x-7{,}5\\cdot 10^{-4}-\\dfrac{42}{x^{2}}"
            },
