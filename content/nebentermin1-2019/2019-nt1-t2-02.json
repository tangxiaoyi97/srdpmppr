              "t": "math",
              "v": "\\bar K'(x)=0\\ \\Rightarrow\\ x_{opt}\\approx 554{,}2\\ \\text{ME}\\quad(\\bar K''(x)>0\\Rightarrow\\text{Minimum})"
            }
          ],
          "result": [
            {
              "t": "math",
              "v": "x_{opt}\\approx 554{,}2\\ \\text{ME}"
            }
          ],
