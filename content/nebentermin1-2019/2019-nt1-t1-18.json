      "solution": [
        {
          "steps": [
            {
              "t": "text",
              "v": "mögliche Vorgehensweise:\n"
            },
            {
              "t": "math",
              "v": "v(t)=15-10\\cdot t"
            },
            {
              "t": "math",
              "v": "s(t)=15\\cdot t-5\\cdot t^{2}+h_0"
            },
            {
              "t": "math",
              "v": "s(0)=1=h_0"
            },
            {
              "t": "math",
              "v": "s(t)=15\\cdot t-5\\cdot t^{2}+1"
            },
            {
              "t": "math",
              "v": "s(2)=30-20+1=11"
            }
          ],
          "result": [
            {
              "t": "text",
              "v": "Der Körper befindet sich nach 2 s in einer Höhe von 11 m über dem Erdboden."
            }
          ],
          "note": "Ein Punkt für die richtige Lösung, wobei die Einheit „m“ nicht angeführt sein muss. Die Aufgabe ist auch dann als richtig gelöst zu werten, wenn bei korrektem Ansatz das Ergebnis aufgrund eines Rechenfehlers nicht richtig ist."
        }
      ],
      "prompt": [
        {
          "t": "text",
          "v": "Geben Sie diejenige Höhe (in Metern) über dem Erdboden an, in der sich der Körper nach 2 s befindet."
        }
      ],
