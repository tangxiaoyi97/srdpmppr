      "prompt": [
        {
          "t": "text",
          "v": "Für ein Säugetier, das sich bewegt, wird die momentane Änderungsrate des Sauerstoffverbrauchs in Abhängigkeit von der Zeit t näherungsweise durch die lineare Funktion "
        },
        {
          "t": "math",
          "v": "u:[0;\\,t_1]\\to\\mathbb{R}"
        },
        {
          "t": "text",
          "v": " mit "
        },
        {
          "t": "math",
          "v": "t_1\\in\\mathbb{R}^+"
        },
        {
          "t": "text",
          "v": " beschrieben (t in min, u(t) in L/min).\n\nEs gilt: "
        },
        {
          "t": "math",
          "v": "u(0)=d"
        },
        {
          "t": "text",
          "v": " mit "
        },
        {
          "t": "math",
          "v": "d\\in\\mathbb{R}^+"
        },
        {
          "t": "text",
          "v": "\n\nDer Graph von u ist in der nachstehenden Abbildung dargestellt."
        },
        {
          "t": "fig",
          "src": "assets/pdf/haupttermin-2023/fig/2023-ht-t2-03-c.png",
          "alt": "Graph der linearen Funktion u auf [0; t1]: steigende Gerade mit u(0)=d"
        },
        {
          "t": "text",
          "v": "Stellen Sie eine Formel zur Berechnung von "
        },
        {
          "t": "math",
          "v": "\\int_0^{t_1} u(t)\\,dt"
        },
        {
          "t": "text",
          "v": " auf. Verwenden Sie dabei "
        },
        {
          "t": "math",
          "v": "t_1"
        },
        {
          "t": "text",
          "v": ", "
        },
        {
          "t": "math",
          "v": "u(t_1)"
        },
        {
          "t": "text",
          "v": " und d."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "expression",
        "canonical": "(ut1 + d) * t1 / 2",
        "vars": [
          "ut1",
          "t1",
          "d"
        ],
        "checker": "cas"
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "result": [
            {
              "t": "math",
              "v": "\\int_0^{t_1} u(t)\\,dt=\\dfrac{(u(t_1)+d)\\cdot t_1}{2}"
            }
          ],
          "note": "Ein Punkt für das richtige Aufstellen der Formel."
        }
      ]
    },
