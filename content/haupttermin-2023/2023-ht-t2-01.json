        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "\\left|\\int_0^6 W(t)\\,dt\\right|=11{,}625"
            }
          ],
          "result": [
            {
              "t": "text",
              "v": "Die Abnahme der Wassermenge im Zeitintervall [0; 6] beträgt 11,625 m³."
            }
          ],
          "note": "Ein Punkt für das richtige Ermitteln der Abnahme der Wassermenge, wobei −11,625 m³ ebenso als richtig zu werten ist."
