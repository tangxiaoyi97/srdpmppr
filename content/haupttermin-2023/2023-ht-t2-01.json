      "prompt": [
        {
          "t": "text",
          "v": "Zum Füllen eines anderen Schwimmbeckens werden p Pumpen verwendet, die pro Stunde jeweils die gleiche Wassermenge pumpen. Für p = 2 beträgt die Fülldauer 19 h. Stellen Sie unter Verwendung der Anzahl p der Pumpen eine Formel zur Berechnung der Fülldauer T (in h) auf."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "expression",
        "canonical": "38/p",
        "vars": [
          "p"
        ],
        "checker": "cas"
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "result": [
            {
              "t": "math",
              "v": "T=\\dfrac{38}{p}"
            }
          ],
          "note": "Ein Punkt für das richtige Aufstellen der Formel."
        }
      ]
    },
    {
      "id": "2023-ht-t2-01-b2",
      "label": "b2",
      "format": "Halboffenes Antwortformat",
      "competencies": [
