              "t": "text",
              "v": "lineare Funktion"
            }
          ],
          [
            {
              "t": "text",
              "v": "quadratische Funktion"
            }
          ],
          [
            {
              "t": "text",
              "v": "Quadratwurzelfunktion"
            }
          ]
        ],
        "pairs": [
          [
            0,
