      "prompt": [
        {
          "t": "text",
          "v": "Die Wassermenge in diesem Schwimmbecken nimmt durch Verdunstung und betriebsbedingte Ursachen ab. Die Funktion "
        },
        {
          "t": "math",
          "v": "W:[0;10]\\to\\mathbb{R},\\ W(t)=-\\tfrac{1}{96}t^3+\\tfrac{1}{4}t^2-\\tfrac{35}{24}t"
        },
        {
          "t": "text",
          "v": " beschreibt die momentane Änderungsrate der Wassermenge (t in h, W(t) in m³/h). Ermitteln Sie die Abnahme der Wassermenge (in m³) im Zeitintervall [0; 6]."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "abnahme",
            "label": "Abnahme der Wassermenge",
            "value": 11.625,
            "tol": 0.01,
            "unit": "m³"
          }
        ]
      },
      "scoring": {
