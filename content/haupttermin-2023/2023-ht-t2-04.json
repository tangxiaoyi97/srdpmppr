      "prompt": [
        {
          "t": "text",
          "v": "Die jährliche Anzahl aller Fluggäste in Österreich ist von 0,14 Millionen im Jahr 1955 auf 28,95 Millionen im Jahr 2017 gestiegen.\n\nDiese zeitliche Entwicklung der Anzahl der Fluggäste in Österreich kann näherungsweise durch die Exponentialfunktion "
        },
        {
          "t": "math",
          "v": "N:\\mathbb{R}_0^+\\to\\mathbb{R}^+"
        },
        {
          "t": "text",
          "v": " mit "
        },
        {
          "t": "math",
          "v": "N(t)=a\\cdot b^{t}"
        },
        {
          "t": "text",
          "v": " mit "
        },
        {
          "t": "math",
          "v": "a,\\,b\\in\\mathbb{R}^+"
        },
        {
          "t": "text",
          "v": " beschrieben werden (t in Jahren mit t = 0 für das Jahr 1955, N(t) in Millionen Fluggästen).\n\nBerechnen Sie a und b."
        }
      ],
      "figures": [],
      "answer": {
        "kind": "numeric",
        "blanks": [
          {
            "id": "a",
            "label": "a",
            "value": 0.14,
            "tol": 0.005
          },
          {
            "id": "b",
            "label": "b",
            "value": 1.089,
            "tol": 0.002
          }
        ]
      },
      "scoring": {
        "mode": "allOrNothing",
        "points": 1
      },
      "points": 1,
      "solution": [
        {
          "result": [
            {
              "t": "math",
              "v": "a=0{,}14;\\quad b=\\sqrt[62]{\\dfrac{28{,}95}{0{,}14}}=1{,}089\\ldots"
            }
          ],
          "note": "Ein Punkt für das richtige Berechnen von a und b."
        }
      ]
    },
