              "t": "text",
              "v": "Richtungsvektoren parallel: "
            },
            {
              "t": "math",
              "v": "\\binom{a}{2}\\parallel\\binom{1}{1}\\Rightarrow a=2"
            },
            {
              "t": "text",
              "v": "; Punkt "
            },
            {
              "t": "math",
              "v": "(2\\,|\\,b)"
            },
            {
              "t": "text",
              "v": " auf g: "
            },
            {
              "t": "math",
              "v": "(1+t\\,|\\,t)=(2\\,|\\,b)\\Rightarrow t=1,\\ b=1"
            }
          ],
          "result": [
            {
              "t": "math",
              "v": "a=2,\\ b=1"
            }
          ],
          "note": "Ein Punkt für das richtige Ermitteln von a und b, ein halber Punkt für nur einen richtigen Wert."
        }
      ],
      "prompt": [
