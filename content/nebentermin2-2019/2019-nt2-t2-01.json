        ]
      },
      "points": 1,
      "solution": [
        {
          "steps": [
            {
              "t": "math",
              "v": "A(t)=\\int_{0}^{t} f_t(x)\\,dx=\\tfrac{t^{3}}{4}-\\tfrac{2\\,t^{3}}{3}+\\tfrac{t^{3}}{2}=\\tfrac{t^{3}}{12}"
